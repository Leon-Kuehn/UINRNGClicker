{
  "name": "roblox-ui-rng-clicker",
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "PlayerClick": {
        "$className": "RemoteEvent"
      }
    },
    "ServerScriptService": {
      "Main": {
        "$path": "src/server/main.server.lua"
      },
      "ClickCurrencyHandler": {
        "$path": "src/ServerScriptService/ClickCurrencyHandler.server.lua"
      },
      "UpgradeSystem": {
        "$path": "src/ServerScriptService/UpgradeSystem.server.lua"
      }
    },
    "StarterPlayer": {
      "StarterCharacterScripts": {
      },
      "StarterPlayerScripts": {
        "CameraController": {
          "$path": "src/client/CameraController.client.lua"
        }
      }
    },
    "StarterGui": {
      "ClickerUI": {
        "$className": "ScreenGui",
        "$properties": {
          "ResetOnSpawn": false,
          "IgnoreGuiInset": true,
          "DisplayOrder": 5
        },
        "ClickButton": {
          "$className": "TextButton",
          "$properties": {
            "Text": "TAP!",
            "TextScaled": true,
            "AutoButtonColor": true
          }
        },
        "CurrencyLabel": {
          "$className": "TextLabel",
          "$properties": {
            "BackgroundTransparency": 1,
            "Text": "Currency: 0",
            "TextScaled": true
          }
        },
        "ClickButtonLocal": {
          "$path": "src/StarterGui/ClickerUI/ClickButton.client.lua"
        },
        "CurrencyLabelLocal": {
          "$path": "src/StarterGui/ClickerUI/CurrencyLabel.client.lua"
        }
      }
    }
  }
}