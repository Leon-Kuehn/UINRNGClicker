{
  "name": "roblox-ui-rng-clicker",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "PlayerClick": {
        "$className": "RemoteEvent"
      },
      "Shared": {
        "$path": "src/shared"
      }
    },

    "ServerScriptService": {
      "ClickCurrencyHandler": {
        "$path": "src/ServerScriptService/ClickCurrencyHandler.server.lua"
      },
      "InitServer": {
        "$path": "src/server/main.server.lua"
      }
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "InitClient": {
          "$path": "src/client/main.client.lua"
        }
      }
    },

    "StarterGui": {
      "ClickerUI": {
        "$className": "ScreenGui",
        "$properties": {
          "ResetOnSpawn": false,
          "IgnoreGuiInset": true
        },
        "ClickButton": {
          "$className": "TextButton",
          "$properties": {
            "Text": "CLICK",
            "TextScaled": true
          }
        },
        "CurrencyLabel": {
          "$className": "TextLabel",
          "$properties": {
            "BackgroundTransparency": 1,
            "Text": "Currency: 0",
            "TextScaled": true
          }
        },
        "ClickButtonScript": {
          "$path": "src/StarterGui/ClickerUI/ClickButton.client.lua"
        },
        "CurrencyLabelScript": {
          "$path": "src/StarterGui/ClickerUI/CurrencyLabel.client.lua"
        }
      }
    },

    "Workspace": {
      "$properties": {
        "FilteringEnabled": true
      },
      "Baseplate": {
        "$className": "Part",
        "$properties": {
          "Anchored": true
        }
      }
    },
    "Lighting": {
      "$properties": {
        "Brightness": 2,
        "GlobalShadows": true,
        "Outlines": false,
        "Technology": "Voxel"
      }
    },
    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
  }
}