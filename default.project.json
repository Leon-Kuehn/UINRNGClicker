{
  "name": "UINRNGClicker",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "$ignoreUnknownInstances": true,
      "Modules": {
        "$path": "src/ReplicatedStorage/Modules"
      },
      "Events": {
        "$className": "Folder",
        "PlayerClick":       { "$className": "RemoteEvent" },
        "RollWeapon":        { "$className": "RemoteEvent" },
        "EquipWeapon":       { "$className": "RemoteEvent" },
        "SellWeapon":        { "$className": "RemoteEvent" },
        "UpdateCurrency":    { "$className": "RemoteEvent" },
        "UpdateInventory":   { "$className": "RemoteEvent" },
        "UpdateLeaderboard": { "$className": "RemoteEvent" },
        "EnterZone":         { "$className": "RemoteEvent" }
      }
    },

    "ServerScriptService": {
      "$ignoreUnknownInstances": true,
      "$path": "src/ServerScriptService"
    },

    "StarterGui": {
      "$ignoreUnknownInstances": true,
      "ClickerUI": {
        "$className": "ScreenGui",
        "$properties": {
          "ResetOnSpawn":    false,
          "IgnoreGuiInset":  true,
          "DisplayOrder":    1
        },
        "ClickerController": {
          "$path": "src/StarterGui/ClickerUI/ClickerController.client.luau"
        }
      },
      "RollUI": {
        "$className": "ScreenGui",
        "$properties": {
          "ResetOnSpawn":   false,
          "IgnoreGuiInset": true,
          "DisplayOrder":   2
        },
        "RollController": {
          "$path": "src/StarterGui/RollUI/RollController.client.luau"
        }
      },
      "LeaderboardUI": {
        "$className": "ScreenGui",
        "$properties": {
          "ResetOnSpawn":   false,
          "IgnoreGuiInset": true,
          "DisplayOrder":   3
        },
        "LeaderboardController": {
          "$path": "src/StarterGui/LeaderboardUI/LeaderboardController.client.luau"
        }
      }
    },

    "StarterPlayer": {
      "$ignoreUnknownInstances": true,
      "StarterPlayerScripts": {
        "$path": "src/StarterPlayer/StarterPlayerScripts"
      }
    }
  }
}
